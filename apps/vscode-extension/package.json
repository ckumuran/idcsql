{
  "name": "idksql-extension",
  "displayName": "IDKSQL",
  "description": "Local AI database copilot",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:idksql.askDatabase"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "idksql.askDatabase",
        "title": "IDKSQL: Ask Database"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsx watch src/extension.ts"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/vscode": "^1.92.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "vscode": "^1.1.37"
  }
}
